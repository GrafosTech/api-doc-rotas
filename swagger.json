    "/api/Rotas/GetByFiltro": {
      "get": {
        "tags": [
          "Rotas"
        ],
        "summary": "Lista rotas com filtros e paginação",
        "description": "Endpoint para listar rotas aplicando filtros por status, data prevista, data de alteração e com suporte a paginação. <br/><br/>Parâmetros de filtro: <br/>- status: Status da roteirização (0=Pendente, 1=Em Andamento, 2=Concluída, 3=Cancelada) <br/>- dataInicio/dataFim: Período para filtrar pela data prevista da rota <br/>- dataAlteracaoInicio/dataAlteracaoFim: Período para filtrar rotas que foram alteradas/atualizadas <br/>- veiculoPlaca: Filtrar por placa do veículo <br/>- motoristaNome: Filtrar por nome do motorista <br/>- pagina: Número da página (começa em 1) <br/>- tamanho: Quantidade de registros por página (máximo 100) <br/><br/>A resposta inclui informações de paginação e a lista de rotas resumidas.",
        "parameters": [
          {
            "name": "status",
            "in": "query",
            "description": "Status da roteirização para filtrar",
            "required": false,
            "schema": {
              "type": "integer",
              "format": "int32",
              "enum": [0, 1, 2, 3]
            }
          },
          {
            "name": "dataInicio",
            "in": "query",
            "description": "Data de início do período para filtrar (formato: YYYY-MM-DD)",
            "required": false,
            "schema": {
              "type": "string",
              "format": "date"
            }
          },
          {
            "name": "dataFim",
            "in": "query",
            "description": "Data de fim do período para filtrar (formato: YYYY-MM-DD)",
            "required": false,
            "schema": {
              "type": "string",
              "format": "date"
            }
          },
          {
            "name": "dataAlteracaoInicio",
            "in": "query",
            "description": "Data e hora de início do período para filtrar rotas alteradas (formato: YYYY-MM-DDTHH:MM:SS.sssZ)",
            "required": false,
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "dataAlteracaoFim",
            "in": "query",
            "description": "Data e hora de fim do período para filtrar rotas alteradas (formato: YYYY-MM-DDTHH:MM:SS.sssZ)",
            "required": false,
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "veiculoPlaca",
            "in": "query",
            "description": "Placa do veículo para filtrar",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "motoristaNome",
            "in": "query",
            "description": "Nome do motorista para filtrar",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "pagina",
            "in": "query",
            "description": "Número da página (padrão: 1)",
            "required": false,
            "schema": {
              "type": "integer",
              "format": "int32",
              "minimum": 1,
              "default": 1
            }
          },
          {
            "name": "tamanho",
            "in": "query",
            "description": "Quantidade de registros por página (padrão: 20, máximo: 100)",
            "required": false,
            "schema": {
              "type": "integer",
              "format": "int32",
              "minimum": 1,
              "maximum": 100,
              "default": 20
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Monitoramento_Backend.Models_API.Rota.RotaListResponse"
                },
                "examples": {
                  "Exemplo 1 - Lista com paginação": {
                    "value": {
                      "dados": [
                        {
                          "id": 123,
                          "idExterno": "ROTA_001",
                          "veiculoPlaca": "ABC1234",
                          "motoristaNome": "João Silva",
                          "rotaRegiaoDescricao": "Grande São Paulo",
                          "dataInicio": "2024-03-25T08:00:00.000Z",
